{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://brkn.local/prompt-composer/schemas/manifest.schema.json",
  "title": "Content Pack Manifest",
  "type": "object",
  "required": ["schema_version", "pack_id", "name", "version", "content_types"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "string", "pattern": "^\\d+\\.\\d+$" },
    "pack_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$",
      "minLength": 2,
      "maxLength": 64,
      "description": "Must equal the first segment of every entry id in this pack."
    },
    "name": { "type": "string", "minLength": 1, "maxLength": 128 },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "author": { "type": "string", "maxLength": 128 },
    "description": { "type": "string", "maxLength": 1024 },
    "content_types": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" }
    },
    "enabled_by_default": { "type": "boolean", "default": true },
    "priority": { "type": "integer", "minimum": 10, "maximum": 1000, "default": 100 },
    "dependencies": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" }
    },
    "tags": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^[a-z0-9_]+$" }
    }
  }
}
