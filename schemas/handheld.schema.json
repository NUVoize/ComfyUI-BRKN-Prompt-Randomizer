{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://brkn.local/prompt-composer/schemas/handheld.schema.json",
  "title": "Handheld",
  "allOf": [
    {
      "$ref": "entry-base.schema.json"
    }
  ],
  "properties": {
    "type": {
      "const": "handheld"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "unspecified": {
          "type": "boolean"
        },
        "carry": {
          "type": "string",
          "maxLength": 32
        }
      }
    }
  }
}
