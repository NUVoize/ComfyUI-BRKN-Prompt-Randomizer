{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://brkn.local/prompt-composer/schemas/camera-preset.schema.json",
  "title": "Camera Preset",
  "allOf": [
    {
      "$ref": "entry-base.schema.json"
    }
  ],
  "properties": {
    "type": {
      "const": "camera_preset"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "framing": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "camera_angle": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        }
      },
      "required": [
        "framing"
      ]
    }
  }
}
